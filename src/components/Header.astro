---
import profile from '../data/profile.json';
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const socialLinks = Object.entries(profile.social).filter(([_, url]) => url);

const navItems = [
  { label: 'Articles', href: `${base}/` },
  { label: 'Works', href: `${base}/works/` },
  { label: 'About', href: `${base}/about/` },
];
---

<header class="header-glass fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="w-full px-6 lg:px-12 xl:px-20 py-4 flex items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-2 text-lg font-semibold tracking-tight" style="color: var(--season-primary);">
      <span>{profile.siteName}</span>
    </a>

    <!-- Desktop nav -->
    <div class="desktop-nav hidden md:flex items-center gap-2">
      <ul class="flex items-center gap-1">
        {navItems.map((item) => {
          const isActive = currentPath === item.href ||
            (item.href !== `${base}/` && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'nav-link relative px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                  isActive ? 'active' : '',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- Divider -->
      <div class="w-px h-5 mx-1" style="background: var(--season-glass-border);"></div>

      <!-- Social icons -->
      <div class="flex items-center gap-1">
        {socialLinks.map(([platform, url]) => (
          <a
            href={platform === 'email' ? `mailto:${url}` : url as string}
            target={platform === 'email' ? undefined : '_blank'}
            rel={platform === 'email' ? undefined : 'noopener noreferrer'}
            class="header-icon w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200"
            aria-label={platform}
          >
            {platform === 'github' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            )}
            {platform === 'twitter' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            )}
            {platform === 'email' && (
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
            )}
            {platform === 'linkedin' && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            )}
          </a>
        ))}
      </div>

      <ThemeToggle />
    </div>

    <!-- Mobile controls -->
    <div class="flex md:hidden items-center gap-2">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="flex items-center justify-center w-9 h-9 rounded-lg transition-colors"
        style="color: var(--season-text);"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-4">
    <ul class="flex flex-col gap-1">
      {navItems.map((item) => {
        const isActive = currentPath === item.href ||
          (item.href !== `${base}/` && currentPath.startsWith(item.href));
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'nav-link block px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                isActive ? 'active' : '',
              ]}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
    <!-- Mobile social links -->
    <div class="flex items-center gap-2 mt-3 px-3">
      {socialLinks.map(([platform, url]) => (
        <a
          href={platform === 'email' ? `mailto:${url}` : url as string}
          target={platform === 'email' ? undefined : '_blank'}
          rel={platform === 'email' ? undefined : 'noopener noreferrer'}
          class="header-icon w-8 h-8 flex items-center justify-center rounded-lg transition-all duration-200"
          aria-label={platform}
        >
          {platform === 'github' && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          )}
          {platform === 'email' && (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          )}
          {platform === 'linkedin' && (
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          )}
        </a>
      ))}
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<style>
  .header-glass {
    background: var(--season-glass-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--season-glass-border);
    box-shadow: 0 4px 20px rgba(100, 120, 160, 0.08);
  }

  :global(html[data-theme="dark"]) .header-glass {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .nav-link {
    color: var(--season-text-muted);
  }
  .nav-link:hover {
    color: var(--season-primary);
    background: rgba(255, 255, 255, 0.3);
  }
  .nav-link.active {
    color: var(--season-primary);
    background: rgba(255, 255, 255, 0.3);
  }

  :global(html[data-theme="dark"]) .nav-link:hover,
  :global(html[data-theme="dark"]) .nav-link.active {
    background: rgba(255, 255, 255, 0.05);
  }

  .header-icon {
    color: var(--season-text-muted);
  }
  .header-icon:hover {
    color: var(--season-primary);
    background: rgba(255, 255, 255, 0.3);
  }
  :global(html[data-theme="dark"]) .header-icon:hover {
    background: rgba(255, 255, 255, 0.05);
  }
</style>

<script is:inline>
  function initMobileMenu() {
    var btn = document.getElementById('mobile-menu-btn');
    if (!btn) return;
    var newBtn = btn.cloneNode(true);
    btn.parentNode.replaceChild(newBtn, btn);
    newBtn.addEventListener('click', function() {
      var menu = document.getElementById('mobile-menu');
      if (menu) menu.classList.toggle('hidden');
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
