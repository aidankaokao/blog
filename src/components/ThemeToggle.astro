---
// Light/dark mode toggle button
// Uses class-based selection to support multiple instances on the page
---

<button
  class="theme-toggle-btn flex items-center justify-center w-9 h-9 rounded-lg transition-all duration-200"
  aria-label="Toggle theme"
>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg class="icon-sun w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg class="icon-moon w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<style>
  .theme-toggle-btn {
    color: var(--season-text-muted);
    background: transparent;
  }
  .theme-toggle-btn:hover {
    color: var(--season-primary);
    background: rgba(255, 255, 255, 0.3);
  }
  :global(html[data-theme="dark"]) .theme-toggle-btn:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  :global(html[data-theme="light"]) .icon-moon { display: block; }
  :global(html[data-theme="dark"]) .icon-sun { display: block; }
</style>
