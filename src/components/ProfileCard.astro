---
import profile from '../data/profile.json';
import GlassCard from './GlassCard.astro';
---

<GlassCard class="p-8 text-center max-w-md mx-auto">
  <div class="flex flex-col items-center gap-4">
    <div class="w-24 h-24 rounded-full overflow-hidden border-2 shadow-md" style="border-color: var(--season-primary-light);">
      <img
        src={profile.avatar}
        alt={profile.name}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>

    <div>
      <h2 class="text-xl font-semibold" style="color: var(--season-primary);">
        {profile.name}
      </h2>
      {profile.tagline && (
        <p class="mt-1 text-sm" style="color: var(--season-text-muted);">
          {profile.tagline}
        </p>
      )}
    </div>

    <p class="text-sm leading-relaxed" style="color: var(--season-text);">
      {profile.bio}
    </p>

    {profile.location && (
      <div class="flex items-center gap-1 text-xs" style="color: var(--season-text-muted);">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{profile.location}</span>
      </div>
    )}
  </div>
</GlassCard>
