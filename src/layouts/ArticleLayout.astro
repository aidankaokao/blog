---
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  slug: string;
}

const { title, description, date, tags = [], slug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = date.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="w-full px-6 lg:px-12 xl:px-20 py-10">
    <div class="max-w-3xl mx-auto">
      <article>
        <!-- Back link -->
        <a
          href={`${base}/`}
          class="inline-flex items-center gap-1 text-sm font-medium mb-8 transition-colors duration-200"
          style="color: var(--season-text-muted);"
          data-animate
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to articles
        </a>

        <!-- Article header -->
        <header class="mb-10" data-animate>
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <time
              datetime={date.toISOString()}
              class="text-sm"
              style="color: var(--season-text-muted);"
            >
              {formattedDate}
            </time>

            {tags.length > 0 && (
              <>
                <span style="color: var(--season-border);">&bull;</span>
                <div class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <span
                      class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
                      style={`background: var(--season-glass-bg); color: var(--season-primary); border: 1px solid var(--season-glass-border);`}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </>
            )}
          </div>

          <h1
            class="text-3xl sm:text-4xl font-bold leading-tight"
            style="color: var(--season-primary);"
            transition:name={`title-${slug}`}
          >
            {title}
          </h1>

          <p class="mt-4 text-lg" style="color: var(--season-text-muted);">
            {description}
          </p>
        </header>

        <!-- Article body -->
        <div data-animate data-animate-delay="1">
          <Prose>
            <slot />
          </Prose>
        </div>
      </article>
    </div>
  </div>
<script>
  function openLinksInNewTab() {
    document.querySelectorAll('.prose a').forEach((a) => {
      if (a.hostname !== location.hostname) {
        a.setAttribute('target', '_blank');
        a.setAttribute('rel', 'noopener noreferrer');
      }
    });
  }
  openLinksInNewTab();
  document.addEventListener('astro:after-swap', openLinksInNewTab);
</script>
</BaseLayout>
